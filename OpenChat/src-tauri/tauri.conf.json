{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenChat",
  "version": "0.2.3",
  "identifier": "com.openchat.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path ./start_backend.ps1) { & ./start_backend.ps1 } elseif (Test-Path ../../start_backend.ps1) { & ../../start_backend.ps1 } else { Write-Error 'start_backend.ps1 not found' -ErrorAction Stop }\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "fullscreen": false,
        "transparent": false,
        "center": true,
        "titleBarStyle": "Visible",
        "theme": null,
        "skipTaskbar": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
